{
  "name": "2fc0f268-7ac0-4975-b33f-cd967a773e7b",
  "type": "Microsoft.Authorization/policyDefinitions",
  "properties": {
    "displayName": "Enforce allowed domains on ECS",
    "policyType": "Custom",
    "mode": "All",
    "description": "Denies creation of Email Communication Service domains unless the domain is explicitly approved.",
    "metadata": {
      "version": "1.0.0",
      "category": "Communication"
    },
    "parameters": {
      "allowedDomains": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed domains",
          "description": "List of approved domain resource names, for example contoso.com"
        },
        "defaultValue": [
          "defensie.nl"
        ]
      },
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect"
        },
        "allowedValues": [
          "Deny",
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Deny"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Communication/emailServices/domains"
          },
          {
            "value": "[last(split(field('name'), '/'))]",
            "notIn": "[parameters('allowedDomains')]"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}